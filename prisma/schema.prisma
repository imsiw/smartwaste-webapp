generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Role {
  USER
  CLEANER
  ADMIN
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  DONE
}

model User {
  id            Int      @id @default(autoincrement())
  telegramId    String   @unique
  username      String?
  firstName     String?
  lastName      String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reports       Report[] @relation("UserReports")
  approved      Report[] @relation("ApprovedReports")
  tasksCreated  Task[]   @relation("TaskCreator")
  tasksAssigned Task[]   @relation("TaskAssignee")
  tasksDone     Task[]   @relation("TaskFinisher")
}

model Report {
  id               Int          @id @default(autoincrement())
  createdByUserId  Int
  createdBy        User         @relation("UserReports", fields: [createdByUserId], references: [id])
  comment          String?
  photoPath        String
  lat              Float?
  lon              Float?
  acc              Float?
  status           ReportStatus @default(PENDING)
  approvedByUserId Int?
  approvedBy       User?        @relation("ApprovedReports", fields: [approvedByUserId], references: [id])
  approvedAt       DateTime?
  rejectedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  task             Task?
}

model Task {
  id               Int        @id @default(autoincrement())
  reportId         Int        @unique
  report           Report     @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdByUserId  Int
  createdBy        User       @relation("TaskCreator", fields: [createdByUserId], references: [id])
  assignedToUserId Int?
  assignedTo       User?      @relation("TaskAssignee", fields: [assignedToUserId], references: [id])
  doneByUserId     Int?
  doneBy           User?      @relation("TaskFinisher", fields: [doneByUserId], references: [id])
  comment          String?
  photoPath        String
  lat              Float?
  lon              Float?
  acc              Float?
  status           TaskStatus @default(NEW)
  doneAt           DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}
